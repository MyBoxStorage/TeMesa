# Copie para `.env` e preencha com valores reais (nunca commite `.env`).

DATABASE_URL=
DIRECT_URL=

# Clerk, Resend, Pagar.me, BC Connect, etc. — ver documentação do projeto

# OBRIGATÓRIO: Atualizar para a URL real após o primeiro deploy no Netlify
# Exemplo: https://SEU-APP.netlify.app ou https://reservas.seudominio.com.br
NEXT_PUBLIC_APP_URL=https://SEU-APP.netlify.app

# Z-API: instância usa ZAPI_TOKEN; webhook recebido valida com ZAPI_CLIENT_TOKEN (header x-z-api-security-token)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Crons (expire-pending, reminders): Authorization: Bearer <secret>
CRON_SECRET=

# ── PostHog (analytics) ──────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
